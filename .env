# Discord Bot Configuration
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE
CLIENT_ID=YOUR_BOT_CLIENT_ID_HERE
GUILD_ID=YOUR_SERVER_GUILD_ID_HERE

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority

# Admin Configuration
ADMIN_ROLE_ID=YOUR_ADMIN_ROLE_ID_HERE

# Optional: Default Channels (Can be set via commands later)
XP_CHANNEL_ID=OPTIONAL_XP_CHANNEL_ID_HERE
LOG_CHANNEL_ID=OPTIONAL_LOG_CHANNEL_ID_HERE
INVITE_LOG_CHANNEL_ID=OPTIONAL_INVITE_LOG_CHANNEL_ID_HERE
LEVEL_UP_CHANNEL_ID=OPTIONAL_LEVEL_UP_CHANNEL_ID_HERE

# Bot Settings
DEFAULT_PREFIX=!
XP_PER_MESSAGE=5
XP_COOLDOWN_SECONDS=60
DEBUG=false

# Railway Specific (Optional)
RAILWAY_STATIC_URL=your-app-name.railway.app
PORT=3000
